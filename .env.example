# Database Configuration
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/mailflow?schema=public"

# Redis Configuration (BullMQ + Rate Limiting)
REDIS_URL="redis://localhost:6379"

# NextAuth Configuration
NEXTAUTH_URL="http://localhost:3000"
# Generate a secret: openssl rand -base64 32
NEXTAUTH_SECRET="your_nextauth_secret_key_here"

# Google OAuth Credentials
GOOGLE_CLIENT_ID="your_google_client_id_here"
GOOGLE_CLIENT_SECRET="your_google_client_secret_here"

# SMTP Configuration Password Encryption Key
# Generate a 32-byte hex key: openssl rand -hex 32
SMTP_ENCRYPTION_KEY="0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef"

# Storage Adapter Settings (local | s3)
STORAGE_ADAPTER="local"

# AWS S3 Storage Settings (Required if STORAGE_ADAPTER=s3)
AWS_ACCESS_KEY_ID="your_aws_access_key_id"
AWS_SECRET_ACCESS_KEY="your_aws_secret_access_key"
AWS_REGION="us-east-1"
AWS_BUCKET_NAME="mailflow-attachments"

# Sentry Monitoring (Optional in Dev)
SENTRY_DSN=""
